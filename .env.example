# ---------- clone (npm run clone) ----------

GITHUB_CLONE_USERNAME=dev-protocol

GITHUB_CLONE_DIR=./repos

FIRST_COMMIT_DATE=2015-01-01

FULL_CLONE=true

# ---------- mirror (npm run mirror) ----------

GITHUB_MIRROR_DIR=./repos
GITHUB_MIRROR_TOKEN=
GITHUB_MIRROR_USERNAME=dev-protocoI

# ---------- replace (npm run replace) ----------
GITHUB_REPLACE_DIR=./repos

GITHUB_REPLACE_USERNAME=your-github-username
GITHUB_REPLACE_USEREMAIL=your-email@example.com
GITHUB_REPLACE_TOKEN=

ADD_COMMIT_DELAY_SINCE_LAST_COMMIT_DAYS=1
AUTO_REMOVE=true

# ---------- release (npm run release) ----------

GITHUB_RELEASE_TOKEN=
GITHUB_RELEASE_USERNAME=dev-protocoI
LAST_UPDATE_DATE=2015-01-01

