# Polymarket — required for `npm run bot -- --live`
# POLYMARKET_PK: wallet private key (hex). CLOB API key/secret/passphrase are derived each run via the SDK (optional: set POLYMARKET_API_* in .env to pin credentials).
POLYMARKET_PK=

# Optional: proxy / funder address (see Polymarket docs)
POLYMARKET_FUNDER=
POLYMARKET_CHAIN_ID=137

# Redis (optional) — e.g. btc_trading:simulation_mode
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2

# Bot behavior & metrics
MARKET_BUY_USD=1
LOG_LEVEL=info
GRAFANA_METRICS_PORT=8000

